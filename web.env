# /storage/ is the default application directory in the container, which is also mounted as a volume, where the
# certificate is copied to when building the Docker image. So, please, specify the certificate name preceded by
# "/storage/".
ASPNETCORE_Kestrel__Certificates__Default__Path=/storage/localhost.pfx
ASPNETCORE_Kestrel__Certificates__Default__Password=
ASPNETCORE_URLS=https://+443;http://+:80

# The following environment variables override the settings in contester/appsettings.json file.
Contester_App__FrontendUrl=https://localhost:443
Contester_App__BackendUrl=https://localhost:443
Contester_App__MaxUploadFileSize=10485760
Contester_App__LoggingEnabled=false
Contester_App__SchemaCreationExecutionTimeoutSeconds=30

# SMTP server
Contester_Email__Host=smtp.gmail.com
Contester_Email__Port=465
Contester_Email__User=example-email@gmail.com
Contester_Email__Password=
Contester_Email__UseStartTls=false
Contester_Email__DoNotCheckCertificateRevocation=false

Contester_Jwt__Issuer=https://localhost:443
Contester_Jwt__Key=a-very-long-and-strong-key
Contester_Jwt__AccessTokenTtlSeconds=600
Contester_Jwt__RefreshTokenTtlSeconds=172800

# If set to true, users will be authenticated only by an email confirmation code.
# This affects all users, including the admin user.
Contester_App__UsePasswordlessAuthentication=true

# On startup the application performs the following steps:
# 1. Verify that this user exists and has the administrator role.
# 2. If step 1 fails:
#    - remove administrator privileges from all users.
# 3. Ensure the user exists (create them if missing).
# 4. Set or update the user's password.
# 5. Ensure the user has administrator privileges (grant them if missing).
#
# Note: the admin user email must exist, since by default email code authentication is used.
Contester_App__AdminUserEmail=admin@contest.er
Contester_App__AdminUserPassword=admin
